name: "CodeQL"
on:
  push:
    branches:
      - main
      - copilot/create-ai-preflight-system
  pull_request:
    branches: [main]
jobs:
  analyze:
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v3
      - uses: github/codeql-action/init@v2
      - uses: github/codeql-action/analyze@v2
