{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Autonomy: Sync Cloud → Local",
      "type": "shell",
      "command": "powershell.exe",
      "args": [
        "-ExecutionPolicy",
        "Bypass",
        "-File",
        "${workspaceFolder}/scripts/local-autonomy-update.ps1"
      ],
      "group": "build",
      "problemMatcher": []
    },
    {
      "label": "Docker: Start All Services",
      "type": "shell",
      "command": "./launch.sh dev",
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "new"
      }
    },
    {
      "label": "Docker: Start Production",
      "type": "shell",
      "command": "./launch.sh prod",
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "new"
      }
    },
    {
      "label": "Docker: Stop All Services",
      "type": "shell",
      "command": "docker compose down",
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      }
    },
    {
      "label": "Docker: View Logs",
      "type": "shell",
      "command": "docker compose logs -f",
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "new"
      }
    },
    {
      "label": "Pre-Flight Check",
      "type": "shell",
      "command": "./preflight-check.sh --verbose",
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      }
    }
  ]
}
