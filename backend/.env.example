# Backend server
PORT=8787
WORKSPACE_ROOT=/workspaces/quantum-x-builder
API_TOKEN=
DATABASE_URL=postgresql://vizualx:password@postgres:5432/vizualx
ENV_PROFILE=prod
STUB_MODE=false

# Telephony (Twilio + Vertex Speech)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
VERTEX_SPEECH_PROJECT_ID=
VERTEX_SPEECH_LOCATION=us-central1
VERTEX_SPEECH_VOICE=en-US-Neural2-J
GEMINI_VOICE_MODEL=gemini-2.0-flash

# RAG / memory
VERTEX_SEARCH_PROJECT_ID=
VERTEX_SEARCH_LOCATION=global
VERTEX_SEARCH_DATASTORE=
BIGQUERY_PROJECT_ID=
BIGQUERY_DATASET=
GCS_BUCKET=

# Connectors
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=
VSCODE_CLIENT_ID=

# Headless browser
PLAYWRIGHT_ENDPOINT=

# Google AutoML
AUTOML_PROJECT_ID=
AUTOML_LOCATION=us-central1

# QXB Pub/Sub
NATS_URL=nats://localhost:4222
NATS_VARZ_URL=http://localhost:8222/varz
NATS_CREDS_PATH=
QXB_DB_URL=
QXB_OBJECT_STORE_URL=
QXB_AUTONOMY_PROFILE_ID=

# Provider order (comma-separated): ollama,groq,gemini,vertex
PROVIDER_ORDER=ollama,groq,gemini,vertex

# Ollama (primary)
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1

# Groq
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# Gemini (API key)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash-exp

# Vertex AI (access token)
VERTEX_ACCESS_TOKEN=
VERTEX_PROJECT_ID=
VERTEX_LOCATION=us-central1
VERTEX_MODEL=gemini-1.5-pro-002

# Feature flags (default off)
providers.ollama.enabled=false
providers.twilio.enabled=false
providers.vertex_speech.enabled=false
providers.vertex_search.enabled=false
providers.bigquery.enabled=false
providers.gcs.enabled=false
providers.playwright.enabled=false
providers.automl.enabled=false
auth.github.enabled=false
auth.google.enabled=false
