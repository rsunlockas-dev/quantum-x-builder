PORT=8787
WORKSPACE_ROOT=/workspaces/quantum-x-builder
API_TOKEN=
DATABASE_URL=
ENV_PROFILE=prod
STUB_MODE=false
PROVIDER_ORDER=ollama,groq,gemini,vertex

# Provider flags (off until configured)
providers.ollama.enabled=false
providers.twilio.enabled=false
providers.vertex_speech.enabled=false
providers.vertex_search.enabled=false
providers.bigquery.enabled=false
providers.gcs.enabled=false
providers.playwright.enabled=false
providers.automl.enabled=false

auth.github.enabled=false
auth.google.enabled=false

# LLM providers
OLLAMA_URL=
OLLAMA_MODEL=
GROQ_API_KEY=
GROQ_MODEL=
GEMINI_API_KEY=
GEMINI_MODEL=
VERTEX_ACCESS_TOKEN=
VERTEX_PROJECT_ID=
VERTEX_LOCATION=
VERTEX_MODEL=

# Telephony (Twilio + Vertex Speech)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
VERTEX_SPEECH_PROJECT_ID=
VERTEX_SPEECH_LOCATION=
VERTEX_SPEECH_VOICE=
GEMINI_VOICE_MODEL=

# RAG / memory
VERTEX_SEARCH_PROJECT_ID=
VERTEX_SEARCH_LOCATION=
VERTEX_SEARCH_DATASTORE=
BIGQUERY_PROJECT_ID=
BIGQUERY_DATASET=
GCS_BUCKET=

# Connectors
