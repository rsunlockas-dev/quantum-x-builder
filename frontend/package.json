{
  "name": "@quantum-x-builder/frontend",
  "displayName": "Quantum X Builder - Frontend",
  "description": "Contract-ready frontend application with autonomous partnership and control panel integration",
  "version": "1.0.0",
  "publisher": "InfinityXOneSystems",
  "author": {
    "name": "InfinityXOneSystems",
    "url": "https://github.com/InfinityXOneSystems"
  },
  "license": "MIT",
  "homepage": "https://github.com/InfinityXOneSystems/quantum-x-builder",
  "repository": {
    "type": "git",
    "url": "https://github.com/InfinityXOneSystems/quantum-x-builder.git"
  },
  "bugs": {
    "url": "https://github.com/InfinityXOneSystems/quantum-x-builder/issues"
  },
  "icon": "assets/icon.png",
  "galleryBanner": {
    "color": "#1a1a2e",
    "theme": "dark"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Visualization",
    "Dashboard",
    "Other"
  ],
  "keywords": [
    "frontend",
    "contract-ready",
    "autonomous-partner",
    "quantum",
    "governance",
    "operations",
    "monitoring",
    "phase5"
  ],
  "activationEvents": [
    "onStartupFinished",
    "onCommand:vizualx.open",
    "onCommand:vizualx.showStatus"
  ],
  "main": "./vscode-extension/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "vizualx.open",
        "title": "Open VIZUAL X Studio",
        "category": "VIZUAL X",
        "icon": "$(circuit-board)"
      },
      {
        "command": "vizualx.showStatus",
        "title": "Show Control Panel Status",
        "category": "VIZUAL X",
        "icon": "$(dashboard)"
      },
      {
        "command": "vizualx.runSelfCheck",
        "title": "Run Self-Check",
        "category": "VIZUAL X",
        "icon": "$(sync)"
      },
      {
        "command": "vizualx.phase3Status",
        "title": "Phase 3 Operations Status",
        "category": "VIZUAL X",
        "icon": "$(pulse)"
      },
      {
        "command": "vizualx.openLowCodePanel",
        "title": "Open Low-Code Workflow Builder",
        "category": "VIZUAL X",
        "icon": "$(symbol-method)"
      }
    ],
    "menus": {
      "commandPalette": [
        {
          "command": "vizualx.open"
        },
        {
          "command": "vizualx.showStatus"
        },
        {
          "command": "vizualx.runSelfCheck"
        },
        {
          "command": "vizualx.phase3Status"
        },
        {
          "command": "vizualx.openLowCodePanel"
        }
      ]
    },
    "keybindings": [
      {
        "command": "vizualx.open",
        "key": "ctrl+shift+x",
        "mac": "cmd+shift+x"
      }
    ],
    "configuration": {
      "title": "VIZUAL X",
      "properties": {
        "vizualx.autoActivate": {
          "type": "boolean",
          "default": true,
          "description": "Automatically show control panel on startup"
        },
        "vizualx.apiEndpoint": {
          "type": "string",
          "default": "http://localhost:3000",
          "description": "API endpoint for admin operations"
        },
        "vizualx.enableMonitoring": {
          "type": "boolean",
          "default": true,
          "description": "Enable real-time operation monitoring"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run build",
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "package": "node build.js",
    "publish": "node publish.js",
    "test": "node -e \"console.log('Tests coming soon')\""
  },
  "devDependencies": {
    "@types/node": "^22.19.10",
    "@types/vscode": "^1.85.0",
    "@vitejs/plugin-react": "^5.0.0",
    "@vscode/vsce": "^3.7.1",
    "typescript": "~5.8.2",
    "vite": "^6.2.0"
  },
  "dependencies": {
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "@google/genai": "^0.3.0",
    "axios": "^1.7.0"
  }
}
