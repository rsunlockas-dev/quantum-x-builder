{
  "name": "vizual-x-vscode",
  "displayName": "Vizual-X Studio",
  "description": "Launch Vizual-X in a VS Code webview on startup.",
  "version": "0.1.0",
  "publisher": "local",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Visualization",
    "Chat",
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished",
    "onCommand:vizualx.open"
  ],
  "main": "./extension.js",
  "contributes": {
    "commands": [
      {
        "command": "vizualx.open",
        "title": "Open Vizual-X Studio",
        "category": "Vizual-X"
      }
    ]
  }
}
