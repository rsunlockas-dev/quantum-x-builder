{
  "name": "quantum-x-builder",
  "version": "1.0.0",
  "description": "Quantum X Builder - Enterprise-grade autonomous system with 110% Protocol",
  "private": true,
  "scripts": {
    "docs:start": "cd website && npm start",
    "docs:build": "cd website && npm run build",
    "docs:serve": "cd website && npm run serve",
    "docs:deploy": "cd website && npm run deploy",
    "docs:clear": "cd website && npm run clear",
    "docs:typecheck": "cd website && npm run typecheck",
    "docs:install": "cd website && npm install",
    "lint": "eslint . --ext .ts,.tsx --max-warnings=0",
    "lint:fix": "eslint . --ext .ts,.tsx --fix",
    "format": "prettier --write .",
    "typecheck": "tsc --noEmit",
    "analyze": "npm run lint && npm run typecheck && npm run test --if-present",
    "diagnose": "node ./tools/diagnose.js",
    "fix": "npm run lint:fix && node ./tools/apply-fixes.js",
    "validate": "npm run typecheck && npm run test --if-present",
    "optimize": "node ./tools/optimize.js",
    "ci": "npm run analyze && npm run validate",
    "test": "vitest run"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/InfinityXOneSystems/quantum-x-builder.git"
  },
  "keywords": [
    "quantum-x-builder",
    "110-protocol",
    "autonomous-system",
    "enterprise"
  ],
  "author": "InfinityXOneSystems",
  "license": "SEE LICENSE IN LICENSE",
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^6.21.0",
    "@typescript-eslint/parser": "^6.21.0",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "prettier": "^3.2.5",
    "typescript": "^5.8.2",
    "ts-node": "^10.9.2",
    "ts-morph": "^21.0.1",
    "vitest": "^1.2.2",
    "@vitest/ui": "^1.2.2"
  }
}
