{
  "name": "vizual-x-admin-control-panel",
  "displayName": "VIZUAL X - Admin Control Panel",
  "description": "Permanent admin control panel for Quantum-X-Builder operations, Phase 3 monitoring, and governance",
  "version": "0.1.0",
  "publisher": "InfinityXOneSystems",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/InfinityXOneSystems/quantum-x-builder"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": ["Visualization", "Chat", "Dashboards", "Other"],
  "keywords": ["admin", "control", "quantum", "governance", "phase3"],
  "activationEvents": [
    "onStartupFinished",
    "onCommand:vizualx.open",
    "onCommand:vizualx.showStatus",
    "onView:vizualx-control-panel"
  ],
  "main": "./vscode-extension/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "vizualx-sidebar",
          "title": "VIZUAL X",
          "icon": "$(dashboard)"
        }
      ]
    },
    "views": {
      "vizualx-sidebar": [
        {
          "id": "vizualx-control-panel",
          "name": "Admin Control Panel",
          "type": "webview",
          "visibility": "visible"
        }
      ]
    },
    "commands": [
      {
        "command": "vizualx.open",
        "title": "Open VIZUAL X Studio",
        "category": "VIZUAL X"
      },
      {
        "command": "vizualx.showStatus",
        "title": "Show Control Panel Status",
        "category": "VIZUAL X"
      },
      {
        "command": "vizualx.runSelfCheck",
        "title": "Run QXB Self Check",
        "category": "VIZUAL X"
      },
      {
        "command": "vizualx.phase3Status",
        "title": "Check Phase 3 Status",
        "category": "VIZUAL X"
      }
    ],
    "keybindings": [
      {
        "command": "vizualx.open",
        "key": "ctrl+shift+x",
        "mac": "cmd+shift+x",
        "when": "!terminalFocus"
      }
    ]
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview"
  }
}
